# API Keys (at least one required for agent execution)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Backend
BIND_ADDR=127.0.0.1:8080
LOG_LEVEL=info,sqlx=warn

# Auth — set this in any deployment; missing value falls back to an insecure default + WARN log.
# Recommend 32+ random chars.
AGENT_K_JWT_SECRET=
# JWT lifetime in seconds (default: 604800 = 7 days)
# JWT_EXPIRY_SECONDS=604800

# Data
# Override to point at a different SQLite DB or directory.
# DATABASE_URL=sqlite://./data/agent-k.db
# AGENT_K_DATA_ROOT=./data
# Upload size limit in bytes (default: 52428800 = 50 MiB)
# AGENT_K_MAX_UPLOAD_BYTES=52428800

# Automation workers — number of tokio worker tasks spawned at boot (default: 2).
# Use 1 for cleaner logs during local debugging.
# AGENT_K_WORKER_COUNT=2

# Default IANA timezone for cron trigger specs that omit `tz`. Invalid or
# unset values fall back to "UTC".
# AGENT_K_DEFAULT_TZ=UTC
